SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# Only needed if you later add admin-side auth operations.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Direct database connection settings for migrations, scripts, and server-side DB clients.
# Prefer DATABASE_URL when you have a single connection string; otherwise set the discrete fields.
DATABASE_URL=
DATABASE_HOST=
DATABASE_PORT=
DATABASE_NAME=
DATABASE_USERNAME=
DATABASE_PASSWORD=

# Dev-only auth test bypass. Enable locally when you want Playwright or manual
# testing to skip real Supabase auth.
AUTH_TEST_BYPASS=false
AUTH_TEST_BYPASS_SECRET=change-me-in-local-dev
# Fixed bypass account: arjayramiso@gmail.com with password Arjay123! or Jayrmiso123!
